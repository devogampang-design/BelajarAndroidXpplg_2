<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DetailListSiswa">

    <ImageView
        android:id="@+id/imgsiswa"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvNamaDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Nama"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/imgsiswa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvNoPunggungDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="No Punggung"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvNamaDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvNegaraDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Negara"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvNoPunggungDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/tvPosisiDetail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Posisi"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/tvNegaraDetail"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>




</androidx.constraintlayout.widget.ConstraintLayout>